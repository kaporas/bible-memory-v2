<?xml version="1.0" encoding="UTF-8"?>
<!--
  배포 방법:
    이 파일을 $TOMCAT_HOME/conf/Catalina/localhost/ 에 배치하거나
    $TOMCAT_HOME/conf/context.xml 의 <Context> 안에 <Resource> 태그를 추가하세요.

  단독 앱 배포 시 (권장):
    파일명을 WAR명과 동일하게 -> ROOT.xml 또는 bible-scoring.xml 로 저장
    위치: $TOMCAT_HOME/conf/Catalina/localhost/ROOT.xml

  사전 준비:
    mysql-connector-j-*.jar 를 $TOMCAT_HOME/lib/ 에 복사해야 합니다.
    (Tomcat 컨테이너가 직접 드라이버를 로딩하므로 WAR 내부 경로는 적용되지 않습니다)
-->
<Context>

    <Resource
        name="jdbc/bible-memory"
        auth="Container"
        type="javax.sql.DataSource"
        driverClassName="com.mysql.cj.jdbc.Driver"
        url="jdbc:mysql://54.180.239.27:3306/bible_scoring?useSSL=false&amp;serverTimezone=Asia/Seoul&amp;characterEncoding=UTF-8&amp;allowPublicKeyRetrieval=true"
        username="root"
        password="root01"

        maxTotal="20"
        maxIdle="10"
        minIdle="2"
        maxWaitMillis="10000"

        validationQuery="SELECT 1"
        testOnBorrow="true"
        testWhileIdle="true"
        timeBetweenEvictionRunsMillis="30000"

        removeAbandonedOnBorrow="true"
        removeAbandonedTimeout="60"
        logAbandoned="true"
    />

</Context>
